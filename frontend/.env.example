# Local development — copy to frontend/.env
VITE_API_BASE_URL=http://localhost:5000
VITE_TENANT_ID=default-tenant

# Vercel (Frontend service): usually leave VITE_API_BASE_URL unset so the app uses /_/backend
# If the backend uses a different routePrefix, set the same path here, e.g.:
# VITE_API_BASE_URL=/_/backend
