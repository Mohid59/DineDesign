# Copy to Vercel → Backend service → Environment Variables
# Use MongoDB Atlas (or similar): MONGO_URI must be reachable from the internet.

PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/fyp_dinedesign?retryWrites=true&w=majority
JWT_SECRET=use_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
DEFAULT_TENANT_ID=default-tenant

# Optional: comma-separated admin seeds — email|name|password
ADMIN_CREDENTIALS=admin@example.com|Admin Name|YourSecurePassword

# Optional AI (menu / chat features)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
